[user]
	name = Ryan West
	email = west.ryan.k@gmail.com
[diff]
	tool = vsdiffmerge
    colormoved=zebra
    context=10
	algorithm = histogram
	renames = true
	mnemonicPrefix = true
[difftool]
#    prompt = true
[difftool "vsdiffmerge"]
	cmd = \"C:\\Program Files\\Microsoft Visual Studio\\2022\\Enterprise\\Common7\\IDE\\CommonExtensions\\Microsoft\\TeamFoundation\\Team Explorer\\vsdiffmerge.exe\" \"$LOCAL\" \"$REMOTE\" //t
	keepBackup = false
[merge]
	tool = kdiff3
[mergetool]
#	prompt = true
    keepBackup = false
[mergetool "vsdiffmerge"]
	cmd = \"C:\\Program Files\\Microsoft Visual Studio\\2022\\Enterprise\\Common7\\IDE\\CommonExtensions\\Microsoft\\TeamFoundation\\Team Explorer\\vsdiffmerge.exe\" \"$REMOTE\" \"$LOCAL\" \"$BASE\" \"$MERGED\" //m
	trustExitCode = true
[push]
	default = upstream
	autoSetupRemote = true
[fetch]
    prune = true
    pruneTags = true
    all = true
[pull]
    rebase = true
[core]
	editor = nvim
	autocrlf = true
	whitespace = cr-at-eol
[alias]
    a   = add
    aa  = add .
    ap  = add -p
    b   = branch
    bd  = branch -d
    bD  = branch -D
    bdr = !pwsh -command Remove-GitRemoteBranch
    bm  = !pwsh -command Rename-GitLocalAndRemoteBranch
    cl  = !pwsh -command Git-CloseAndClean
    ch  = checkout
    chb = checkout -b
    cfg = config --global -e
    co  = commit
    com = commit -m
    coa = commit --amend
    con = commit --amend --no-edit
    cowip = commit -m "WIP"
    cp  = cherry-pick
    cpc = cherry-pick --continue
    cpa = cherry-pick --abort
    d   = show-whitespace diff
    ds  = show-whitespace diff --staged
    f   = fetch
    l   = log
    g   = log --graph --oneline --branches
    ga  = log --graph --oneline --all
    mt  = mergetool
    or  = !pwsh -command Invoke-GitRemoteUrl
    opr = !pwsh -command Invoke-GitPullRequest
    ps  = push
    psf = push -f
    pl  = pull
    rep = remote prune origin
    rs  = reset
    rsh = reset --hard
    rswip = reset head~
    rb  = rebase
    rbi = rebase -i
    rbc = rebase --continue
    rba = rebase --abort
    s   = status
    sh  = stash
    up  = !pwsh -command Invoke-GitPullMain

    show-whitespace = !git -c core.pager='sed s/\\ /·/g | sed s/\\\t/￫\\ \\ \\ /g | less -R' $@ && :
[init]
	defaultBranch = main
#[core]
    #pager = sed 's/ /·/g' | sed 's/\t/[90m→[0m       /g' | less -R
[safe]
	directory = D:/source/design-system
[log]
	date = iso-local
[column]
	ui = auto
[tag]
	sort = version:refname
[rebase]
	updateRefs = true
	autosquash = true
